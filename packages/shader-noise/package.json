{
  "name": "@frapx/shader-noise",
  "version": "0.1.0",
  "description": "Lightweight GLSL noise helpers for @frapx/shader.",
  "keywords": [
    "webgl",
    "shader",
    "glsl",
    "noise",
    "perlin",
    "simplex",
    "fbm"
  ],
  "type": "module",
