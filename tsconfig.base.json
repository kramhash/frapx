{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@frapx/shader": ["./packages/shader/src/index.ts"],
      "@frapx/shader/*": ["./packages/shader/src/*.ts"],
      "@frapx/shader-react": ["./packages/shader-react/src/index.ts"]
    }
  }
}
